{
  "name": "bytemd-plugin-github-alerts",
  "type": "module",
  "version": "0.0.2",
  "packageManager": "pnpm@10.33.4",
  "description": "ByteMD plugin to support GitHub Alerts",
  "author": "Frankie <1426203851@qq.com>",
  "license": "MIT",
  "homepage": "https://github.com/tofrankie/bytemd-plugin/packages/github-alerts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tofrankie/bytemd-plugin.git",
    "directory": "packages/github-alerts"
  },
  "bugs": {
    "url": "https://github.com/tofrankie/bytemd-plugin/issues"
  },
  "keywords": [
    "bytemd",
    "plugin",
    "alerts",
    "github",
    "gfm"
  ],
  "exports": {
    ".": {
