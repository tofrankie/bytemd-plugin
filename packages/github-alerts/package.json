  "files": [
    "CHANGELOG.md",
    "dist",
    "index.css"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "prepublishOnly": "run-s typecheck build",
    "typecheck": "tsc --noEmit",
    "publint": "publint"
  },
  "peerDependencies": {
    "bytemd": "^1.5.0"
